# Gateway Environment Variables
APP_ENV=development
PORT=3000
HOST=localhost

# Service Discovery
CONSUL_URL=http://localhost:8500

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# JWT Authentication
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=24h

# Services (will be auto-discovered in production)
SERVICE_USERS=http://localhost:3001
SERVICE_PRODUCTS=http://localhost:3002
