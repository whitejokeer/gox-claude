<template auth="required" layout="dashboard">
  <div class="user-list">
    <h1>{{.Title}}</h1>
    
    <div class="toolbar">
      <shared-button text="Add User" hx-get="/users/new" hx-target="#modal" />
      <input type="search" 
             placeholder="Search users..." 
             hx-post="/users/search" 
             hx-trigger="keyup changed delay:500ms" 
             hx-target="#user-list" />
    </div>
    
    <div id="user-list">
      {{range .Users}}
        <user-card 
          id="{{.ID}}" 
          name="{{.Name}}" 
          email="{{.Email}}" 
          featured />
      {{end}}
    </div>
    
    <div id="modal"></div>
  </div>
</template>

<go>
package pages

import (
    "net/http"
    "encoding/json"
)

type UserListPage struct {
    Title string        `json:"title"`
    Users []User        `json:"users"`
    SearchQuery string  `json:"search_query"`
}

type User struct {
    ID    int    `json:"id"`
    Name  string `json:"name"`
    Email string `json:"email"`
}

// Constructor - se llama cuando se renderiza la página
func NewUserListPage(r *http.Request) (*UserListPage, error) {
    users, err := loadUsersFromDB()
    if err != nil {
        return nil, err
    }
    
    return &UserListPage{
        Title: "User Management",
        Users: users,
    }, nil
}

func (p *UserListPage) HandleSearch(w http.ResponseWriter, r *http.Request) {
    query := r.FormValue("search")
    p.SearchQuery = query
    
    // Filter users based on search
    filtered := p.filterUsers(query)
    
    // Return partial HTML for HTMX
    w.Header().Set("Content-Type", "text/html")
    p.renderUserList(w, filtered)
}

func (p *UserListPage) HandleNewUser(w http.ResponseWriter, r *http.Request) {
    // Return new user form
    w.Write([]byte(`<form hx-post="/users" hx-target="#user-list">
        <input name="name" placeholder="Name" required />
        <input name="email" type="email" placeholder="Email" required />
        <button type="submit">Create</button>
    </form>`))
}

func loadUsersFromDB() ([]User, error) {
    // Mock implementation
    return []User{
        {ID: 1, Name: "John Doe", Email: "john@example.com"},
        {ID: 2, Name: "Jane Smith", Email: "jane@example.com"},
    }, nil
}

func (p *UserListPage) filterUsers(query string) []User {
    // Implementation here
    return p.Users
}

func (p *UserListPage) renderUserList(w http.ResponseWriter, users []User) {
    // Render partial HTML
}
</go>

<style scoped>
.user-list {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
}

.toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    gap: 1rem;
}

.toolbar input[type="search"] {
    flex: 1;
    max-width: 400px;
    padding: 0.5rem 1rem;
    border: 1px solid #ddd;
    border-radius: 4px;
}

#user-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
}

@media (max-width: 768px) {
    .toolbar {
        flex-direction: column;
    }
    
    .toolbar input[type="search"] {
        max-width: 100%;
    }
}
</style>