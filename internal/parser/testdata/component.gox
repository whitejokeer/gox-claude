<template>
  <div class="user-card">
    <img src="{{.Avatar}}" alt="{{.Name}}" class="avatar" />
    <div class="info">
      <h3>{{.Name}}</h3>
      <p>{{.Email}}</p>
      <button hx-post="/users/{{.ID}}/follow" hx-target="#follow-status">
        Follow
      </button>
    </div>
  </div>
</template>

<go>
package components

import (
    "net/http"
)

type UserCard struct {
    ID     int    `gox:"required"`
    Name   string `gox:"required"`
    Email  string `gox:"required"`
    Avatar string `gox:"optional"`
}

func (c *UserCard) HandleFollow(w http.ResponseWriter, r *http.Request) {
    // Handle follow action
    w.Write([]byte("Following!"))
}

func (c *UserCard) Validate() error {
    if c.Name == "" {
        return errors.New("name is required")
    }
    if c.Email == "" {
        return errors.New("email is required")
    }
    return nil
}
</go>

<style scoped>
.user-card {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 16px;
    display: flex;
    gap: 12px;
}

.avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
}

.info h3 {
    margin: 0 0 4px 0;
    color: #333;
}

.info p {
    margin: 0 0 8px 0;
    color: #666;
    font-size: 0.9rem;
}

button {
    background: #007bff;
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
}

button:hover {
    background: #0056b3;
}
</style>