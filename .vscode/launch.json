{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug GOX CLI",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/gox",
      "args": [],
      "env": {
        "GOX_DEBUG": "true"
      },
      "showLog": true
    },
    {
      "name": "GOX new project",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/gox",
      "args": ["new", "project", "test-app"],
      "env": {
        "GOX_DEBUG": "true"
      },
      "showLog": true
    },
    {
      "name": "GOX dev",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/gox",
      "args": ["dev"],
      "env": {
        "GOX_DEBUG": "true"
      },
      "showLog": true
    },
    {
      "name": "Run Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}",
      "args": ["-v"],
      "env": {},
      "showLog": true
    },
    {
      "name": "Test Current Package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-v"],
      "showLog": true
    }
  ]
}